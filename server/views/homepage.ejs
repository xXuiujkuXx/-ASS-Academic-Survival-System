        </div>

        <div class="panel panel3">
            <div class="bottom-trans">
                <h2>ผลงาน</h2>
            </div>
            <div class="hover-overlay">
                <div class="hover-content">
                    <h2>ผลงาน</h2>
                    <p>รวบรวมผลงานและความสำเร็จของนักศึกษาและคณาจารย์</p>
                </div>
            </div>
        </div>

        <div class="panel panel4">
            <div class="bottom-trans">
                <h2>สมัคร</h2>
            </div>
            <div class="hover-overlay">
                <div class="hover-content">
                    <h2>สมัคร</h2>
                    <p>เปิดโอกาสสำหรับผู้สนใจร่วมเรียนรู้และพัฒนาศักยภาพ</p>
                </div>
            </div>
        </div>
    </div>
    <div class="head-text">
        <h1>ข่าวล่าสุด</h1>
    </div>
    <div class="dets">

        <%- include('partials/news-slider', {
            title: "ผลงานวิจัยของอาจารย์และนักศึกษาได้รับรางวัลผลงานวิจัยดีเด่น",
            description: "ผลงานวิจัยด้านเทคโนโลยีสารสนเทศของอาจารย์และนักศึกษาภาควิชา ได้รับรางวัลผลงานวิจัยดีเด่นจากการประชุมวิชาการระดับนานาชาติ โดยงานวิจัยดังกล่าวมุ่งเน้นการพัฒนาระบบประมวลผลข้อมูลที่มีความรวดเร็วและแม่นยำมากขึ้น",
            images: [
                "https://static.wikitide.net/projectsekaiwiki/b/bf/Mizuki_20_art.png",
                "https://static.wikitide.net/projectsekaiwiki/f/f1/Mizuki_7_art.png",
                "https://static.wikitide.net/projectsekaiwiki/3/33/Mizuki_9_art.png"
            ],
            layout: "first"
        }) %>

        <%- include('partials/news-slider', {
            title: "นักศึกษาภาควิชาคว้ารางวัลการแข่งขันเขียนโปรแกรมระดับมหาวิทยาลัย",
            description: "นักศึกษาจากภาควิชาคอมพิวเตอร์สามารถคว้ารางวัลจากการแข่งขันเขียนโปรแกรมระดับมหาวิทยาลัย ซึ่งมีผู้เข้าแข่งขันจากหลายสถาบัน โดยทีมของภาควิชาสามารถแก้โจทย์อัลกอริทึมที่ซับซ้อนได้ภายในเวลาที่กำหนด",
            images: [
                "https://static.wikitide.net/projectsekaiwiki/b/bf/Mizuki_20_art.png",
                "https://static.wikitide.net/projectsekaiwiki/f/f1/Mizuki_7_art.png",
                "https://static.wikitide.net/projectsekaiwiki/3/33/Mizuki_9_art.png"
            ],
            layout: "bottom"
        }) %>

    </div>

</body>
<script>
    document.querySelectorAll(".header").forEach(header => {

        const slides = header.querySelectorAll(".slide");
        const leftBtn = header.querySelector(".nav-btn.left");
        const rightBtn = header.querySelector(".nav-btn.right");

        let currentIndex = 0;
        let interval = setInterval(nextSlide, 5000);

        function showSlide(index) {
            slides.forEach(slide => slide.classList.remove("active"));
            slides[index].classList.add("active");
        }

        function nextSlide() {
            currentIndex = (currentIndex + 1) % slides.length;
            showSlide(currentIndex);
        }

        function prevSlide() {
            currentIndex = (currentIndex - 1 + slides.length) % slides.length;
            showSlide(currentIndex);
        }

        rightBtn.addEventListener("click", () => {
            nextSlide();
            resetInterval();
        });

        leftBtn.addEventListener("click", () => {
            prevSlide();
            resetInterval();
        });

        function resetInterval() {
            clearInterval(interval);
            interval = setInterval(nextSlide, 5000);
        }

    });
    
    
</script>
</html>
    <% } %>
    <div class="main-container">
        <div class="panel panel1">
            <div class="bottom-trans">
                <h2>ภาควิชา</h2>
            </div>
            <div class="hover-overlay">
                <div class="hover-content">
                    <h2>ภาควิชา</h2>
                    <p>มุ่งพัฒนาบุคลากรด้านเทคโนโลยีและนวัตกรรมสู่ยุคดิจิทัล</p>
                </div>
            </div>
        </div>

        <div class="panel panel2">
            <div class="bottom-trans">
                <h2>หลักสูตร</h2>
            </div>
            <div class="hover-overlay">
                <div class="hover-content">
                    <h2>หลักสูตร</h2>
                    <p>เรียนรู้ทั้งทฤษฎีและปฏิบัติด้านการพัฒนาเทคโนโลยีสมัยใหม่</p>
                </div>

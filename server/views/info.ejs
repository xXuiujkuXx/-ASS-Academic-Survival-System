<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/reg-student-style.css">
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <title>Document</title>
</head>
<script>
    function openOverlay() {
        document.getElementById("passwordOverlay").style.display = "flex";
    }

    function closeOverlay() {
        document.getElementById("passwordOverlay").style.display = "none";
    }

    function closeIfOutside(event) {
        if (event.target.classList.contains("overlay")) {
            closeOverlay();
        }
    }
</script>
<!-- CHANGE PASSWORD OVERLAY -->
<div class="overlay" id="passwordOverlay" onclick="closeIfOutside(event)">
    <div class="box">
        <button class="close-btn" onclick="closeOverlay()">✕</button>
        <h2>เปลี่ยนรหัสผ่าน</h2>
        <form class="ch" action="/changepass" method="POST">
            <input type="password" placeholder="รหัสผ่านเก่า" name="opass">
            <input type="password" placeholder="รหัสผ่านใหม่" name="npass">
            <input type="password" placeholder="ยืนยันรหัสผ่านใหม่" name="cnpass">
            <button type="submit" class="change-btn">เปลี่ยนรหัส</button>
        </form>
    </div>
</div>
<!-- CHANGE PASSWORD OVERLAY -->
<body>
    <% if (user.role === 'admin') { %>
        <%- include('navbar-staff') %>
    <% } else if (user.role === 'teacher') { %>
        <%- include('navbar-teacher') %>
    <% } else if (user.role === 'student') { %>
        <%- include('navbar') %>
    <% } %>
    <div class="banner">
        <div class="text">
            <h1>ข้อมูลส่วนตัว</h1>
            
        </div>
        <div class="darker"></div>
        <img src="/img/info-bg.jpg">
    </div>
    <div class="profile-section">
        <div class="pfp-container">
            <div class="profile-left">
                <div class="profile-image">
                    <img src="/uploads/profile/<%= user.account_id %>.png"
                        onerror="
                            if(this.src.includes('.png')){
                                this.src='/uploads/profile/<%= user.account_id %>.jpg';
                            } else {
                                this.src='/img/default-profile.jpg';
                            }
                        ">
                </div>

                <button class="edit-btn" onclick="document.getElementById('pfpUpload').click()">
                    แก้ไขรูป
                </button>

                <form id="uploadForm" action="/upload-profile" method="POST" enctype="multipart/form-data">
                    <input type="file" id="pfpUpload" name="profile" accept="image/*" style="display:none" onchange="document.getElementById('uploadForm').submit()">
                </form>
            </div>
            <div class="profile-right">
                <div class="info-row"><span>ชื่อ (ไทย) :</span><%=pd.first_name%> <%=pd.last_name%></div>
                <div class="info-row"><span>อีเมล :</span> <%= sc ? sc.email : user.email %></div>
                <div class="info-row">
                    <span>รหัสผ่าน :</span> <%= '*'.repeat(user.password_hash.length) %>
                </div>
                <button class="pass-btn" onclick="openOverlay()">เปลี่ยนรหัสผ่าน</button>
                <% if (pd.gender == 'male') { %>
                    <div class="info-row"><span>เพศ :</span> ชาย</div>
                <%} else {%>
                    <div class="info-row"><span>เพศ :</span> หญิง</div>
                <%}%>

                <% if (pd.telephone) { %>
                    <div class="info-row"><span>เบอร์โทรศัพท์ :</span> <%=pd.telephone %></div>
                <%} else {%>
                    <div class="info-row"><span>เบอร์โทรศัพท์ :</span> -</div>
                <%}%>
                <div class="info-row">
                    <span>วันเกิด :</span>
                    <%= new Date(pd.date_of_birth).toLocaleDateString('th-TH', {
                        day: 'numeric',
                        month: 'long',
                        year: 'numeric'
                    }) %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>